{
  "name": "NativeEntryProject",
  "entry": {
    "type": "native",
    "linux": "native/build/sq-native-entry",
    "windows": "native/build-windows-x86_64/sq-native-entry.exe"
  },
  "script_dirs": [
    "scripts"
  ],
  "native_projects": [
    {
      "dir": "native",
      "build": [
        "./build.sh"
      ]
    }
  ],
  "linux": {
    "deb": {
      "download": true,
      "packages": [
        "libc6",
        "libc6-dev"
      ]
    },
    "arches": [
      {
        "arch": "x86_64",
        "entry_linux": "native/build-linux-x86_64/sq-native-entry",
        "inherit_native_projects": false,
        "native_projects": [
          {
            "dir": "native",
            "build": [
              "BUILD_DIR=build-linux-x86_64 MESON_CROSS_FILE=\"$SQGI_LINUX_MESON_CROSS_FILE\" ./build.sh"
            ]
          }
        ]
      },
      {
        "arch": "aarch64",
        "entry_linux": "native/build-linux-aarch64/sq-native-entry",
        "inherit_native_projects": false,
        "native_projects": [
          {
            "dir": "native",
            "build": [
              "BUILD_DIR=build-linux-aarch64 MESON_CROSS_FILE=\"$SQGI_LINUX_MESON_CROSS_FILE\" ./build.sh"
            ]
          }
        ]
      }
    ]
  },
  "windows": {
    "msys2_prefix": "mingw64",
    "build": [],
    "native_projects": [
      {
        "dir": "native",
        "build": [
          "BUILD_DIR=build-windows-x86_64 MESON_CROSS_FILE=\"$SQGI_MESON_CROSS_FILE\" ./build.sh"
        ]
      }
    ]
  }
}
