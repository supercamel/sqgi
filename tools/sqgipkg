  sqgipkg SCRIPT --name NAME --target appimage [options]
  sqgipkg --manifest sqgipkg.json [options]
  sqgipkg SCRIPT --name NAME --target win-dir
  sqgipkg SCRIPT --name NAME --target win-nsis
  sqgipkg --target win-sysroot [--msys2-prefix mingw64]
  sqgipkg SCRIPT --name NAME --target all
  sqgipkg SCRIPT --name NAME --target appdir
  sqgipkg SCRIPT --name NAME --target tarball

