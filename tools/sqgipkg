        local contents = "[Settings]\n"
        if (gtk_theme != "")
            contents += "gtk-theme-name=" + gtk_theme + "\n"
        if (gtk_icon_theme != "")
            contents += "gtk-icon-theme-name=" + gtk_icon_theme + "\n"
        if (gtk_font_name != "")
            contents += "gtk-font-name=" + gtk_font_name + "\n"
        if (gtk_prefer_dark)
            contents += "gtk-application-prefer-dark-theme=true\n"
        return contents
    }

