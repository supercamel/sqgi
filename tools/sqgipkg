  --manifest FILE     Load distribution settings from a JSON manifest (default: sqgipkg.json when present)
  --name NAME          Application name shown to users (default: project directory)
  --target TARGET      Package target: appimage, win-dir, win-nsis, win-sysroot, all, appdir, tarball (default: appimage)
