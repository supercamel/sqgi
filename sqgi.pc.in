prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: sqgi
Description: Squirrel-language bindings for GLib / GObject / GIRepository
Version: @PROJECT_VERSION@
Requires: glib-2.0 gobject-2.0 gobject-introspection-1.0
Libs: -L${libdir} -lsqgi
Cflags: -I${includedir}/sqgi
